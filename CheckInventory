-- ===== 1. Dynamic Data Modules (Rarity Checking) =====
local PetDataDb = nil
local SeedDataDb = nil

local RARITY_WEIGHTS = {
    ["common"] = 1,
    ["uncommon"] = 2,
    ["rare"] = 3,
    ["epic"] = 4,
    ["legendary"] = 5,
    ["mythic"] = 6,
    ["super"] = 7,
    ["divine"] = 8,
    ["secret"] = 9,
    ["exotic"] = 10,
}

local function isMythicOrAbove(rarityStr)
    if not rarityStr then return false end
    local r = tostring(rarityStr):lower()
    local weight = RARITY_WEIGHTS[r]
    if weight and weight >= 6 then
        return true
    end
    if r:find("mythic") or r:find("super") or r:find("divine") or r:find("secret") or r:find("exotic") or r:find("god") or r:find("void") then
        return true
    end
    return false
end

local function getItemRarity(db, itemName)
    if not db or not itemName then return nil end
    local val = db[itemName]
    if val then
        if type(val) == "string" then
            return val
        elseif type(val) == "table" then
            return val.Rarity or val.rarity or val.Tier or val.tier
        end
    end
    for k, v in pairs(db) do
        if tostring(k) == itemName then
            if type(v) == "string" then return v end
            if type(v) == "table" then
                return v.Rarity or v.rarity or v.Tier or v.tier
            end
        end
        if type(v) == "table" then
            if tostring(v.Name) == itemName or tostring(v.Id) == itemName or tostring(v.ItemName) == itemName then
                return v.Rarity or v.rarity or v.Tier or v.tier
            end
        end
    end
    return nil
end

local function initDatabases()
    local paths = {
        { "SharedModules", "PetData" },
        { "SharedModules", "PetsData" },
        { "SharedData", "PetData" },
        { "SharedData", "PetsData" },
        { "SharedModules", "SeedData" },
        { "SharedModules", "SeedsData" },
        { "SharedData", "SeedData" },
        { "SharedData", "SeedsData" },
    }
    for _, path in ipairs(paths) do
        local folder = ReplicatedStorage:FindFirstChild(path[1])
        if folder then
            local mod = folder:FindFirstChild(path[2])
            if mod and mod:IsA("ModuleScript") then
                local ok, res = pcall(require, mod)
                if ok and type(res) == "table" then
                    if path[2]:lower():find("pet") then
                        PetDataDb = res
                    elseif path[2]:lower():find("seed") then
                        SeedDataDb = res
                    end
                end
            end
        end
    end
    if not PetDataDb or not SeedDataDb then
        for _, desc in ipairs(ReplicatedStorage:GetDescendants()) do
            if desc:IsA("ModuleScript") then
                local name = desc.Name:lower()
                if not name:find("client") and not name:find("controller") and not name:find("network") then
                    local ok, res = pcall(require, desc)
                    if ok and type(res) == "table" then
                        if not PetDataDb then
                            for k, v in pairs(res) do
                                if type(v) == "table" and (v.Name == "Unicorn" or k == "Unicorn" or v.Id == "Unicorn") then
                                    PetDataDb = res
                                    break
                                end
                            end
                        end
                        if not SeedDataDb then
                            for k, v in pairs(res) do
                                if type(v) == "table" and (v.Name == "Venus Fly Trap" or k == "Venus Fly Trap" or v.Id == "Venus Fly Trap") then
                                    SeedDataDb = res
                                    break
                                end
                            end
                        end
                    end
                end
            end
            if PetDataDb and SeedDataDb then break end
        end
    end
end

pcall(initDatabases)

-- Rarity Checkers
local function isMythicPet(petEntry)
    if type(petEntry) ~= "table" then return false end
    local rarity = petEntry.Rarity or petEntry.rarity
    if rarity and isMythicOrAbove(rarity) then
        return true
    end
    local petName = petEntry.Name or petEntry.ItemName or petEntry.Id
    if petName then
        local dbRarity = getItemRarity(PetDataDb, petName)
        if dbRarity and isMythicOrAbove(dbRarity) then
            return true
        end
        local pNameLower = tostring(petName):lower()
        local mythicPets = {
            ["unicorn"] = true,
            ["golden dragonfly"] = true,
            ["bear"] = true,
            ["monkey"] = true,
            ["raccoon"] = true,
            ["black dragon"] = true,
            ["ice serpent"] = true,
            ["rainbow dragon"] = true,
            ["golden dragon"] = true,
            ["void cat"] = true,
            ["void dog"] = true,
            ["golden pig"] = true,
            ["rainbow pegacorn"] = true,
            ["demon"] = true,
            ["angel"] = true,
            ["god"] = true,
            ["phoenix"] = true,
            ["pegasus"] = true
        }
        if mythicPets[pNameLower] then
            return true
        end
    end
    return false
end

local function isMythicSeed(seedName)
    if not seedName then return false end
    local dbRarity = getItemRarity(SeedDataDb, seedName)
    if dbRarity and isMythicOrAbove(dbRarity) then
        return true
    end
    local sNameLower = tostring(seedName):lower()
    local mythicSeeds = {
        ["venus fly trap"] = true,
        ["pomegranate"] = true,
        ["poison apple"] = true,
        ["venom spitter"] = true,
        ["moon bloom"] = true,
        ["dragon's breath"] = true,
        ["rainbow"] = true,
        ["gold"] = true,
        ["golden"] = true,
        ["rainbow seed"] = true,
        ["gold seed"] = true,
        ["golden seed"] = true,
        ["ghost pepper"] = true
    }
    if mythicSeeds[sNameLower] then
        return true
    end
    return false
end

local function getParentGui()
    if gethui then
        local ok, res = pcall(gethui)
        if ok and res then return res end
    end
    -- Prioritize PlayerGui for 100% guaranteed player visibility in executors
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui") or LocalPlayer:WaitForChild("PlayerGui", 5)
    if playerGui then return playerGui end
    
    local target
    local ok = pcall(function()
        target = game:GetService("CoreGui")
    end)
    if ok and target then return target end
    return workspace
end

