-- ===== 5. UI Updating and Syncing =====
local active = true

local function updateUI()
    if not active then return end
    
    local displayData = {}
    
    -- Gather replica data
    local inv = cachedReplica and cachedReplica.Data and cachedReplica.Data.Inventory
    if not inv then
        EmptyLabel.Visible = true
        EmptyLabel.Text = "Waiting for game data..."
        -- Remove any row frames
        for _, child in ipairs(ScrollFrame:GetChildren()) do
            if child:IsA("Frame") and child.Name:sub(1, 4) == "Row_" then
                child:Destroy()
            end
        end
        return
    end
    
    -- 1. Check Pets
    local petCounts = {}
    local hasPets = false
    if type(inv.Pets) == "table" then
        for _, entry in pairs(inv.Pets) do
            if isMythicPet(entry) then
                local name = entry.Name or entry.ItemName or entry.Id or "Unknown Pet"
                petCounts[name] = (petCounts[name] or 0) + 1
                hasPets = true
            end
        end
    end
    
    if hasPets then
        table.insert(displayData, { type = "section", text = "PETS" })
        local sortedPets = {}
        for name, count in pairs(petCounts) do
            table.insert(sortedPets, { name = name, count = count })
        end
        table.sort(sortedPets, function(a, b) return a.count > b.count end)
        for _, pet in ipairs(sortedPets) do
            table.insert(displayData, { type = "item", name = pet.name, count = pet.count })
        end
    end
    
    -- 2. Check Seeds
    local seedsList = {}
    if type(inv.Seeds) == "table" then
        for seedName, count in pairs(inv.Seeds) do
            local c = tonumber(count) or 0
            if c > 0 and isMythicSeed(seedName) then
                table.insert(seedsList, { name = seedName .. " Seed", count = c })
            end
        end
    end
    
    if #seedsList > 0 then
        table.insert(displayData, { type = "section", text = "SEEDS" })
        table.sort(seedsList, function(a, b) return a.count > b.count end)
        for _, seed in ipairs(seedsList) do
            table.insert(displayData, { type = "item", name = seed.name, count = seed.count })
        end
    end
    
    -- 3. Check Gears (Super Sprinkler & Super Watering Can)
    local gearsList = {}
    if type(inv.Sprinklers) == "table" then
        for name, count in pairs(inv.Sprinklers) do
            local c = tonumber(count) or 0
            if c > 0 and name == "Super Sprinkler" then
                table.insert(gearsList, { name = name, count = c })
            end
        end
    end
    if type(inv.WateringCans) == "table" then
        for name, count in pairs(inv.WateringCans) do
            local c = tonumber(count) or 0
            if c > 0 and name == "Super Watering Can" then
                table.insert(gearsList, { name = name, count = c })
            end
        end
    end
    
    if #gearsList > 0 then
        table.insert(displayData, { type = "section", text = "GEARS" })
        table.sort(gearsList, function(a, b) return a.count > b.count end)
        for _, gear in ipairs(gearsList) do
            table.insert(displayData, { type = "item", name = gear.name, count = gear.count })
        end
    end
    
    -- Sync rows
    local children = ScrollFrame:GetChildren()
    local rowInstances = {}
    for _, child in ipairs(children) do
        if child:IsA("Frame") and child.Name:sub(1, 4) == "Row_" then
            table.insert(rowInstances, child)
        end
    end
    
    table.sort(rowInstances, function(a, b)
        return (tonumber(a.Name:sub(5)) or 0) < (tonumber(b.Name:sub(5)) or 0)
    end)
    
    local numReq = #displayData
    local numCurr = #rowInstances
    
    if numReq == 0 then
        EmptyLabel.Visible = true
        EmptyLabel.Text = "No Mythic+ items found"
    else
        EmptyLabel.Visible = false
    end
    
    if numCurr < numReq then
        for i = numCurr + 1, numReq do
            local row = Instance.new("Frame")
            row.Name = "Row_" .. tostring(i)
            row.Size = UDim2.new(1, 0, 0, 24)
            row.BackgroundTransparency = 1
            row.BorderSizePixel = 0
            
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Name = "NameLabel"
            nameLabel.Size = UDim2.new(0.7, 0, 1, 0)
            nameLabel.Position = UDim2.new(0, 4, 0, 0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Font = Enum.Font.GothamBold
            nameLabel.TextSize = 13
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.Parent = row
            
            local countLabel = Instance.new("TextLabel")
            countLabel.Name = "CountLabel"
            countLabel.Size = UDim2.new(0.3, -8, 1, 0)
            countLabel.Position = UDim2.new(0.7, 0, 0, 0)
            countLabel.BackgroundTransparency = 1
            countLabel.Font = Enum.Font.GothamBold
            countLabel.TextSize = 13
            countLabel.TextXAlignment = Enum.TextXAlignment.Right
            countLabel.Parent = row
            
            row.Parent = ScrollFrame
            table.insert(rowInstances, row)
        end
    elseif numCurr > numReq then
        for i = numReq + 1, numCurr do
            rowInstances[i]:Destroy()
            rowInstances[i] = nil
        end
    end
    
    for i, data in ipairs(displayData) do
        local row = rowInstances[i]
        if not row then continue end
        
        row.LayoutOrder = i
        local nameLabel = row:FindFirstChild("NameLabel")
        local countLabel = row:FindFirstChild("CountLabel")
        
        if data.type == "section" then
            row.Size = UDim2.new(1, 0, 0, 28)
            if nameLabel then
                nameLabel.Text = data.text
                nameLabel.TextColor3 = Color3.fromRGB(0, 220, 255)
                nameLabel.Font = Enum.Font.GothamBold
                nameLabel.TextSize = 12
            end
            if countLabel then
                countLabel.Visible = false
            end
        else
            row.Size = UDim2.new(1, 0, 0, 22)
            if nameLabel then
                nameLabel.Text = data.name
                nameLabel.TextColor3 = Color3.fromRGB(220, 220, 230)
                nameLabel.Font = Enum.Font.GothamBold
                nameLabel.TextSize = 13
            end
            if countLabel then
                countLabel.Visible = true
                countLabel.Text = tostring(data.count)
                countLabel.TextColor3 = Color3.fromRGB(241, 196, 15)
                countLabel.Font = Enum.Font.GothamBold
                countLabel.TextSize = 13
            end
        end
    end
end

