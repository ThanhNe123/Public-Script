local function getDisplayName(item)
    if item.Pet and item.Pet.Name then
        return item.Pet.Name
    end
    return item.ItemName or "Unknown"
end

local function getCategoryInfo(category)
    return CATEGORY_DISPLAY[category] or { icon = "📦", color = TEXT_SECONDARY }
end

local sortOrder = 0

local function updateItemRow(displayName, category, count)
    local catInfo = getCategoryInfo(category)
    local rowKey = displayName .. "|" .. category

    if itemRows[rowKey] then
        -- Update existing row
        local row = itemRows[rowKey]
        local countLabel = row:FindFirstChild("CountLabel")
        if countLabel then
            local oldCount = tonumber(countLabel:GetAttribute("RawCount")) or 0
            local newCount = oldCount + count
            countLabel:SetAttribute("RawCount", newCount)
            countLabel.Text = "x" .. tostring(newCount)
            -- Flash animation
            TweenService:Create(countLabel, TweenInfo.new(0.15), { TextColor3 = Color3.fromRGB(255, 255, 100) }):Play()
            task.delay(0.3, function()
                if countLabel and countLabel.Parent then
                    TweenService:Create(countLabel, TweenInfo.new(0.3), { TextColor3 = GREEN }):Play()
                end
            end)
            -- Flash row background
            TweenService:Create(row, TweenInfo.new(0.15), { BackgroundTransparency = 0.2 }):Play()
            task.delay(0.3, function()
                if row and row.Parent then
                    TweenService:Create(row, TweenInfo.new(0.3), { BackgroundTransparency = 0.7 }):Play()
                end
            end)
        end
    else
        -- Remove empty label if exists
        if emptyLabel and emptyLabel.Parent then
            emptyLabel:Destroy()
            emptyLabel = nil
        end

        -- Create new row
        sortOrder = sortOrder + 1
        local row = Instance.new("Frame")
        row.Name = "Item_" .. rowKey
        row.Size = UDim2.new(1, 0, 0, 28)
        row.BackgroundColor3 = catInfo.color
        row.BackgroundTransparency = 0.85
        row.BorderSizePixel = 0
        row.LayoutOrder = sortOrder
        row.Parent = scrollFrame

        local rowCorner = Instance.new("UICorner")
        rowCorner.CornerRadius = UDim.new(0, 5)
        rowCorner.Parent = row

        -- Icon
        local iconLbl = Instance.new("TextLabel")
        iconLbl.Size = UDim2.new(0, 22, 1, 0)
        iconLbl.Position = UDim2.new(0, 4, 0, 0)
        iconLbl.BackgroundTransparency = 1
        iconLbl.Font = Enum.Font.GothamBold
        iconLbl.Text = catInfo.icon
