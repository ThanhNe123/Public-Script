function self.Shutdown()
    self.Running = false
    for _, connection in ipairs(self.Connections) do
        pcall(function()
            connection:Disconnect()
        end)
    end
    if env[key] == self then
        env[key] = nil
    end
    -- Cleanup UI
    pcall(function()
        if ScreenGui and ScreenGui.Parent then
            ScreenGui:Destroy()
        end
    end)
end

local function fetchInbox()
    local ok, result = pcall(function()
        return Networking.Mailbox.OpenInbox:Fire()
    end)
    if not ok then
        warn("[AutoClaimMailbox] Lỗi khi lấy hòm thư:", result)
        return nil
    end
    if typeof(result) ~= "table" then
        warn("[AutoClaimMailbox] Dữ liệu hòm thư không hợp lệ:", typeof(result))
        return nil
    end
    return typeof(result.Mailbox) == "table" and result.Mailbox or result
end

local function claimAll()
    if self.Busy or not Config.Enabled then
        return
    end
    self.Busy = true
    
    local inbox = self.Inbox or fetchInbox()
    self.Inbox = nil
    local found, claimed = 0, 0
    local totalMails = 0

    if inbox then
        -- Đếm tổng số mail đang có trong Inbox
        for _ in pairs(inbox) do
            totalMails += 1
        end

        for mailId, mailData in pairs(inbox) do
            if not self.Running or found >= Config.MaxClaimsPerPass then
                break
            end
            
            if type(mailId) == "string" and (self.RetryAt[mailId] or 0) <= os.clock() then
                found += 1
                local ok, success, reason = pcall(function()
                    return Networking.Mailbox.Claim:Fire(mailId)
                end)
                
                if ok and success then
                    claimed += 1
                    self.TotalClaimed += 1

                    -- Track items for UI
                    if type(mailData) == "table" then
                        processClaimedMail(mailData)
                    end

                    self.RetryAt[mailId] = nil
                    print(string.format("[AutoClaimMailbox] ✅ Đã nhận: %s | Mail: %d | Items: %d", mailId, Stats.TotalMailsClaimed, Stats.TotalItemsCollected))
                else
                    self.RetryAt[mailId] = os.clock() + Config.RetryDelay
                    warn("[AutoClaimMailbox] Từ chối nhận:", mailId, ok and tostring(reason) or tostring(success))
                end
                task.wait(Config.ClaimDelay)
            end
        end
    end
    
    self.Busy = false
    
    -- Báo cáo tổng số mail tìm thấy hoặc trạng thái hòm thư
    if totalMails > 0 then 
        print(string.format("[AutoClaimMailbox] Đang có: %d mail trong hòm", totalMails))
        self.EmptyReported = false 
    elseif not self.EmptyReported then 
        print("[AutoClaimMailbox] Hòm thư trống")
        self.EmptyReported = true 
    end
    
    self.Wake = claimed > 0 or found >= Config.MaxClaimsPerPass
end

table.insert(self.Connections, Networking.Mailbox.Updated.OnClientEvent:Connect(function(update)
    if typeof(update) == "table" and typeof(update.Mailbox) == "table" then
        self.Inbox = update.Mailbox
    end
    self.Wake = true
end))

