-- ===== PROCESS CLAIMED ITEMS FOR UI =====
local function processClaimedMail(mailData)
    Stats.TotalMailsClaimed = Stats.TotalMailsClaimed + 1

    if mailData and type(mailData.Items) == "table" then
        for _, item in ipairs(mailData.Items) do
            local displayName = getDisplayName(item)
            local count = item.Count or 1
            local category = item.Category or "Unknown"

            Stats.TotalItemsCollected = Stats.TotalItemsCollected + count

            local rowKey = displayName .. "|" .. category
            if Stats.ItemDetails[rowKey] then
                Stats.ItemDetails[rowKey].count = Stats.ItemDetails[rowKey].count + count
            else
                Stats.ItemDetails[rowKey] = { count = count, category = category, name = displayName }
            end

            updateItemRow(displayName, category, count)
        end
    end

    updateUI()
end

